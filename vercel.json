{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/daily", "schedule": "30 3 * * *" },
    { "path": "/api/cron/prematch", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/results", "schedule": "0 * * * *" }
  ]
}